---
import BaseLayout from '../layouts/BaseLayout.astro';
import instagramFeed from '../data/instagram-feed.json';

const cvUrl = `${import.meta.env.BASE_URL}cv.pdf`;
const linkedInUrl = 'https://www.linkedin.com/in/catalina-brand-g%C3%B3mez-549922209/';
const upworkUrl = 'https://www.upwork.com/freelancers/~010e5a923c0079adb5?mp_source=share';
const githubUrl = 'https://github.com/catabg';
const profileImageUrl = `${import.meta.env.BASE_URL}profile.jpg`;
const instagramProfileUrl = 'https://www.instagram.com/box_club_col/';
const instagramPosts = instagramFeed.slice(0, 6);

const socialLinks = [
  { id: 'linkedin', label: 'LinkedIn', url: linkedInUrl },
  { id: 'upwork', label: 'Upwork', url: upworkUrl },
  { id: 'github', label: 'GitHub', url: githubUrl }
];

const services = [
  {
    title: { es: 'Investigación y empaque de contenido', en: 'Content research and packaging' },
    body: {
      es: 'Investigo eventos, noticias, temas o referencias y los convierto en piezas listas para redes o newsletters.',
      en: 'I research events, news, topics, or references and turn them into social or newsletter-ready assets.'
    }
  },
  {
    title: { es: 'Operaciones de contenido digital', en: 'Digital content operations' },
    body: {
      es: 'Organizo calendarios, publicaciones, sistemas de información y procesos de apoyo para equipos pequeños.',
      en: 'I organize calendars, publishing workflows, information systems, and support processes for small teams.'
    }
  },
  {
    title: { es: 'Edición de video y soporte para canales', en: 'Video editing and channel support' },
    body: {
      es: 'Edito videos en DaVinci Resolve, preparo thumbnails y apoyo el paquete de contenido para YouTube.',
      en: 'I edit in DaVinci Resolve, prepare thumbnails, and support the full YouTube content package.'
    }
  }
];

const portfolioBaseUrl = `${import.meta.env.BASE_URL}portfolio/canva`;
const numberedFiles = (total) => Array.from({ length: total }, (_, index) => `${index + 1}.png`);
const prefixedFiles = (prefix, total) => Array.from({ length: total }, (_, index) => `${prefix}-${index + 1}.png`);

const canvaCampaigns = [
  { slug: 'il-bracco', title: { es: 'Il Bracco', en: 'Il Bracco' }, files: numberedFiles(4) },
  { slug: 'dia-de-muertos-scottsdale', title: { es: 'Día de Muertos Scottsdale', en: 'Dia de Muertos Scottsdale' }, files: numberedFiles(4) },
  { slug: 'dreamy-draw-music-festival', title: { es: 'Dreamy Draw Music Festival', en: 'Dreamy Draw Music Festival' }, files: numberedFiles(4) },
  { slug: 'western-week', title: { es: 'Western Week', en: 'Western Week' }, files: numberedFiles(3) },
  { slug: 'la-la-land-kind-cafe', title: { es: 'La La Land Kind Cafe', en: 'La La Land Kind Cafe' }, files: numberedFiles(4) },
  { slug: 'cafe-monarch', title: { es: 'Cafe Monarch', en: 'Cafe Monarch' }, files: numberedFiles(3) },
  { slug: 'city-winery', title: { es: 'City Winery', en: 'City Winery' }, files: numberedFiles(4) },
  { slug: 'virgen-del-carmen', title: { es: 'Virgen del Carmen (ES/EN)', en: 'Virgen del Carmen (ES/EN)' }, files: [...prefixedFiles('es', 5), ...prefixedFiles('en', 5)] },
  { slug: 'carrusel-julio-25-28', title: { es: 'Carrusel Julio 25-28 (ES/EN)', en: 'July 25-28 Carousel (ES/EN)' }, files: [...prefixedFiles('es', 7), ...prefixedFiles('en', 7)] },
  { slug: 'estratos-medellin-espanol', title: { es: 'Estratos Medellín (Español)', en: 'Estratos Medellin (Spanish)' }, files: numberedFiles(6) },
  { slug: 'navidad-en-medellin-espanol', title: { es: 'Navidad en Medellín (Español)', en: 'Christmas in Medellin (Spanish)' }, files: numberedFiles(5) },
  { slug: 'conciertos-medellin', title: { es: 'Conciertos Medellín (ES/EN)', en: 'Medellin Concerts (ES/EN)' }, files: [...prefixedFiles('es', 7), ...prefixedFiles('en', 7)] }
].map((campaign) => ({
  ...campaign,
  slides: campaign.files.map((file, index) => ({
    src: `${portfolioBaseUrl}/${campaign.slug}/${file}`,
    index: index + 1
  }))
}));

const featuredCampaignSlugs = ['dia-de-muertos-scottsdale', 'il-bracco', 'conciertos-medellin'];
const archiveCampaigns = canvaCampaigns.filter((campaign) => !featuredCampaignSlugs.includes(campaign.slug));

const navLinks = [
  { href: '#work', label: { es: 'Trabajo', en: 'Work' } },
  { href: '#services', label: { es: 'Servicios', en: 'Services' } },
  { href: '#process', label: { es: 'Proceso', en: 'Process' } },
  { href: '#experience', label: { es: 'Experiencia', en: 'Experience' } },
  { href: '#contact', label: { es: 'Contacto', en: 'Contact' } }
];

const proofStats = [
  { value: '75+', label: { es: 'slides de portfolio', en: 'portfolio slides' } },
  { value: 'ES/EN', label: { es: 'contenido bilingüe', en: 'bilingual content' } },
  { value: '2024+', label: { es: 'producción freelance', en: 'freelance production' } }
];

const featuredCaseStudies = [
  {
    campaignSlug: 'dia-de-muertos-scottsdale',
    eyebrow: { es: 'Contenido local', en: 'Local content' },
    title: {
      es: 'Carruseles de eventos y cultura para Scottsdale Scoop',
      en: 'Event and culture carousels for Scottsdale Scoop'
    },
    problem: {
      es: 'Convertir información dispersa de restaurantes, fechas y eventos en piezas fáciles de leer.',
      en: 'Turn scattered restaurant, date, and event information into easy-to-read social pieces.'
    },
    role: {
      es: 'Research, estructura, copy corto y empaque visual en Canva.',
      en: 'Research, structure, short copy, and visual packaging in Canva.'
    },
    outcome: {
      es: 'Paquetes listos para publicar con contexto claro y ritmo editorial.',
      en: 'Ready-to-publish packages with clear context and editorial pacing.'
    }
  },
  {
    campaignSlug: 'il-bracco',
    eyebrow: { es: 'Food and lifestyle', en: 'Food and lifestyle' },
    title: {
      es: 'Perfiles de restaurantes con criterio editorial',
      en: 'Restaurant features with editorial judgment'
    },
    problem: {
      es: 'Presentar restaurantes y experiencias sin que el contenido se sintiera como una lista fría.',
      en: 'Present restaurants and experiences without making the content feel like a flat list.'
    },
    role: {
      es: 'Selección de ángulos, jerarquía de información y visuales consistentes.',
      en: 'Angle selection, information hierarchy, and consistent visuals.'
    },
    outcome: {
      es: 'Piezas que ayudan a decidir rápido: qué es, por qué importa y qué esperar.',
      en: 'Pieces that help people decide quickly: what it is, why it matters, and what to expect.'
    }
  },
  {
    campaignSlug: 'conciertos-medellin',
    eyebrow: { es: 'Contenido bilingüe', en: 'Bilingual content' },
    title: {
      es: 'Carrusel informativo de eventos bilingüe',
      en: 'Bilingual informational event carousel'
    },
    problem: {
      es: 'Organizar información de fechas, artistas y ciudad para audiencias distintas.',
      en: 'Organize dates, artists, and city context for different audiences.'
    },
    role: {
      es: 'Versiones ES/EN, síntesis, orden narrativo y adaptación de carrusel.',
      en: 'ES/EN versions, synthesis, narrative order, and carousel adaptation.'
    },
    outcome: {
      es: 'Un mismo paquete editorial adaptado para lectores locales e internacionales.',
      en: 'One editorial package adapted for local and international readers.'
    }
  }
].map((project) => {
  const campaign = canvaCampaigns.find((item) => item.slug === project.campaignSlug);

  return {
    ...project,
    slides: campaign?.slides ?? []
  };
});

const processSteps = [
  {
    title: { es: 'Investigo el contexto', en: 'I research the context' },
    body: {
      es: 'Reúno fuentes, fechas, referencias y restricciones antes de escribir.',
      en: 'I gather sources, dates, references, and constraints before writing.'
    }
  },
  {
    title: { es: 'Ordeno la historia', en: 'I structure the story' },
    body: {
      es: 'Decido qué va primero, qué sobra y qué necesita una explicación más clara.',
      en: 'I decide what leads, what can go, and what needs clearer explanation.'
    }
  },
  {
    title: { es: 'Empaco para publicar', en: 'I package for publishing' },
    body: {
      es: 'Convierto el material en captions, carruseles, videos o sistemas de contenido.',
      en: 'I turn the material into captions, carousels, videos, or content systems.'
    }
  }
];

const toolkitTools = [
  { name: 'Canva', icon: `${import.meta.env.BASE_URL}tool-logos/canva.svg` },
  { name: 'DaVinci Resolve', icon: `${import.meta.env.BASE_URL}tool-logos/davinciresolve.svg` },
  { name: 'Codex', icon: `${import.meta.env.BASE_URL}tool-logos/openai.svg` },
  { name: 'Notion', icon: `${import.meta.env.BASE_URL}tool-logos/notion.svg` },
  { name: 'GitHub', icon: `${import.meta.env.BASE_URL}tool-logos/github.svg` },
  { name: 'Perplexity', icon: `${import.meta.env.BASE_URL}tool-logos/perplexity.svg` },
  { name: 'CapCut', icon: `${import.meta.env.BASE_URL}tool-logos/capcut.svg` },
  { name: 'Discord', icon: `${import.meta.env.BASE_URL}tool-logos/discord.svg` }
];

const youtubeVideos = [
  {
    id: 'o5aoaCHlARo',
    url: 'https://youtu.be/o5aoaCHlARo',
    title: { es: "Don't learn n8n in 2026 - do THIS instead", en: "Don't learn n8n in 2026 - do THIS instead" }
  },
  {
    id: 'IQ1_5jPiQoE',
    url: 'https://youtu.be/IQ1_5jPiQoE?si=5EOj_sDxUbUZU3Nr',
    title: {
      es: "This Claude Code Plugin Transforms Vibe Coders Into Senior Engineers",
      en: "This Claude Code Plugin Transforms Vibe Coders Into Senior Engineers"
    }
  },
  {
    id: 'XjLUtu3ieOU',
    url: 'https://youtu.be/XjLUtu3ieOU?si=9rDXJwPY5n1uIMBl',
    title: {
      es: 'Make your First $1000 with Claude Code (Complete Guide)',
      en: 'Make your First $1000 with Claude Code (Complete Guide)'
    }
  },
  {
    id: 'sns-ks-bUJM',
    url: 'https://youtu.be/sns-ks-bUJM?si=q1TMivVpcBKPvDQi',
    title: {
      es: "Claude Code's 1M Context Changes Everything",
      en: "Claude Code's 1M Context Changes Everything"
    }
  }
];

const experienceItems = [
  {
    role: { es: 'Freelance Digital Content Strategist and Operations Specialist', en: 'Freelance Digital Content Strategist and Operations Specialist' },
    company: { es: 'Clientes editoriales, e-commerce y creators', en: 'Editorial, e-commerce, and creator clients' },
    period: { es: '2024 - Presente', en: '2024 - Present' },
    description: {
      es: 'Research, carruseles, captions, video editing, systems de contenido y soporte operativo para proyectos digitales.',
      en: 'Research, carousels, captions, video editing, content systems, and operational support for digital projects.'
    }
  },
  {
    role: { es: 'Practicante de Comunicaciones y Cultura', en: 'Communications and Culture Intern' },
    company: { es: 'Noble Union', en: 'Noble Union' },
    period: { es: 'Enero - Julio 2025', en: 'January - July 2025' },
    description: {
      es: 'Gestión de información interna y apoyo en cultura organizacional.',
      en: 'Internal information management and support for organizational culture.'
    }
  },
  {
    role: { es: 'Auxiliar Administrativo', en: 'Administrative Assistant' },
    company: { es: 'Extension Cultural UdeA', en: 'UdeA Cultural Extension' },
    period: { es: 'Mayo 2023 - Enero 2024', en: 'May 2023 - January 2024' },
    description: {
      es: 'Logística, investigación y apoyo a comunicaciones institucionales.',
      en: 'Logistics, research, and institutional communications support.'
    }
  },
  {
    role: { es: 'Team Leader de Customer Service', en: 'Customer Service Team Leader' },
    company: { es: 'Xtendo Group', en: 'Xtendo Group' },
    period: { es: 'Abril 2021 - Febrero 2023', en: 'April 2021 - February 2023' },
    description: {
      es: 'Supervisión, resolución de casos, mejora operativa y acompañamiento de agentes para Chile y Perú.',
      en: 'Supervision, case resolution, operational improvement, and agent support for Chile and Peru.'
    }
  },
  {
    role: { es: 'Gestora pedagógica', en: 'Pedagogical Facilitator' },
    company: { es: 'Secretaría de Movilidad de Medellín', en: 'Medellin Mobility Secretariat' },
    period: { es: 'Julio - Diciembre 2019', en: 'July - December 2019' },
    description: {
      es: 'Comunicación pública, pedagogía y trabajo en territorio.',
      en: 'Public communication, pedagogy, and field work.'
    }
  }
];
---

<BaseLayout
  title="Catalina Brand Gómez - Digital Content Strategist and Operations Specialist"
  description="Research-driven digital content strategist and operations specialist. Portfolio, content systems, editing, and AI-assisted workflows."
>
  <header class="site-header" aria-label="Main navigation">
    <nav class="anchor-nav">
      {navLinks.map((link) => (
        <a href={link.href}>
          <span class="i18n es">{link.label.es}</span>
          <span class="i18n en">{link.label.en}</span>
        </a>
      ))}
    </nav>
    <div class="control-row">
      <div class="lang-switch" role="group" aria-label="Selector de idioma">
        <button class="lang-btn" type="button" data-lang-set="es" aria-pressed="false">ES</button>
        <button class="lang-btn" type="button" data-lang-set="en" aria-pressed="false">EN</button>
      </div>
      <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
        <span aria-hidden="true">◐</span>
        <span data-theme-label>Modo día</span>
      </button>
    </div>
  </header>

  <section class="masthead hero-shell">
    <div class="identity">
      <p class="eyebrow">
        <span class="i18n es">Contenido digital, investigación y operaciones creativas</span>
        <span class="i18n en">Content strategy, research and creative operations</span>
      </p>
      <h1>Catalina Brand Gómez</h1>
      <p class="headline">
        <span class="i18n es">Transformo ideas, información y referencias en contenido claro, visual y listo para publicar.</span>
        <span class="i18n en">I turn scattered information into clear, visual, ready-to-publish content.</span>
      </p>
      <p class="hero-summary">
        <span class="i18n es">
          Soy comunicadora estratega especializada en contenido digital. Trabajo en investigación, estructura, copy, carruseles, edición de video y sistemas de publicación para marcas, creators y proyectos editoriales.
        </span>
        <span class="i18n en">
          I am a strategic communicator specialized in digital content. I work across research, structure, copy, carousels, video editing, and publishing systems for brands, creators, and editorial projects.
        </span>
      </p>
      <p class="location">
        <span class="i18n es">Vivo en Colombia. Disponible para trabajo remoto e internacional.</span>
        <span class="i18n en">Based in Colombia. Available for remote and international work.</span>
      </p>

      <div class="social-row">
        <a class="email-link" href="mailto:catabg1410@gmail.com" aria-label="Enviar email">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2.1-.25 6.9 5.14 6.9-5.14H5.1Zm13.4 12a1.25 1.25 0 0 0 1.25-1.25V8.38l-7.3 5.44a.75.75 0 0 1-.9 0l-7.3-5.44v8.87c0 .7.56 1.25 1.25 1.25h12.5Z" />
          </svg>
          <span>catabg1410@gmail.com</span>
        </a>

        <div class="icon-links" aria-label="Redes sociales">
          {socialLinks.map((item) => (
            <a href={item.url} target="_blank" rel="noreferrer" aria-label={item.label}>
              {item.id === 'linkedin' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4.98 3.5C3.88 3.5 3 4.39 3 5.48S3.88 7.46 4.98 7.46c1.09 0 1.98-.88 1.98-1.98S6.07 3.5 4.98 3.5ZM3.27 8.94h3.42V20H3.27V8.94Zm5.55 0h3.28v1.57h.05c.46-.86 1.57-1.77 3.24-1.77 3.47 0 4.11 2.28 4.11 5.24V20h-3.42v-5.33c0-1.27-.02-2.91-1.77-2.91-1.77 0-2.04 1.38-2.04 2.81V20H8.82V8.94Z" />
                </svg>
              )}
              {item.id === 'upwork' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.5 7.1c-1.7 0-3 .8-4 2.3l-.6-.9c-.9-1.4-1.7-2.8-2.2-4.2H7.9v7.4c0 2-.8 3.1-2.3 3.1S3.3 13.7 3.3 11.8V7.3H.5v4.4c0 3.5 2 5.6 5 5.6s5-2 5-5.5v-.7l.4.6c1 1.7 2.4 3.6 5 3.6 3.2 0 5.6-2.4 5.6-5.8 0-3-2-5.4-5-5.4Zm0 8c-1.6 0-2.6-1.1-3.8-3.1l-.2-.3.1-.2c.7-1.4 1.8-2.2 3.2-2.2 1.6 0 2.7 1.2 2.7 2.9 0 1.7-1 2.9-2.6 2.9Z" />
                </svg>
              )}
              {item.id === 'github' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.33-1.74-1.33-1.74-1.08-.74.09-.72.09-.72 1.19.08 1.82 1.2 1.82 1.2 1.06 1.8 2.78 1.28 3.46.97.1-.76.42-1.28.76-1.57-2.66-.3-5.47-1.32-5.47-5.87 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.11-3.16 0 0 1-.32 3.3 1.21a11.42 11.42 0 0 1 6 0c2.3-1.53 3.3-1.21 3.3-1.21.65 1.64.23 2.86.11 3.16.77.83 1.24 1.88 1.24 3.17 0 4.56-2.81 5.57-5.49 5.86.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.82.58A12 12 0 0 0 12 .3Z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <div class="actions">
        <a class="cta primary" href="#work">
          <span class="i18n es">Ver trabajo seleccionado</span>
          <span class="i18n en">View selected work</span>
        </a>
        <a class="cta" href={cvUrl}>
          <span class="i18n es">Descargar CV</span>
          <span class="i18n en">Download CV</span>
        </a>
        <a class="cta quiet" href={upworkUrl} target="_blank" rel="noreferrer">Upwork</a>
      </div>
    </div>

    <div class="hero-aside">
      <div class="photo-wrap">
        <img src={profileImageUrl} alt="Foto de perfil de Catalina Brand Gómez" class="profile-photo" />
      </div>
      <div class="proof-rail" aria-label="Portfolio summary">
        {proofStats.map((stat) => (
          <div>
            <strong>{stat.value}</strong>
            <span class="stat-label i18n es">{stat.label.es}</span>
            <span class="stat-label i18n en">{stat.label.en}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="services" class="stream-section">
    <div class="section-kicker">
      <p class="eyebrow">
        <span class="i18n es">Servicios</span>
        <span class="i18n en">Services</span>
      </p>
      <h2>
        <span class="i18n es">Apoyo de contenido para equipos que necesitan claridad y ejecución.</span>
        <span class="i18n en">Content support for teams that need clarity and execution.</span>
      </h2>
    </div>
    <div class="service-grid">
      {services.map((service) => (
        <article class="service-card">
          <h3>
            <span class="i18n es">{service.title.es}</span>
            <span class="i18n en">{service.title.en}</span>
          </h3>
          <p>
            <span class="i18n es">{service.body.es}</span>
            <span class="i18n en">{service.body.en}</span>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="work" class="stream-section work-section">
    <div class="section-kicker">
      <p class="eyebrow">
        <span class="i18n es">Trabajo seleccionado</span>
        <span class="i18n en">Selected work</span>
      </p>
      <h2>
        <span class="i18n es">Casos que muestran cómo pienso, no solo cómo se ven las piezas.</span>
        <span class="i18n en">Case studies that show how I think, not only how the pieces look.</span>
      </h2>
    </div>

    <div class="case-stack">
      {featuredCaseStudies.map((project) => (
        <article class="case-card">
          <div class="case-copy">
            <p class="item-meta">
              <span class="i18n es">{project.eyebrow.es}</span>
              <span class="i18n en">{project.eyebrow.en}</span>
            </p>
            <h3>
              <span class="i18n es">{project.title.es}</span>
              <span class="i18n en">{project.title.en}</span>
            </h3>
            <dl class="case-points">
              <div>
                <dt>
                  <span class="i18n es">Problema</span>
                  <span class="i18n en">Problem</span>
                </dt>
                <dd>
                  <span class="i18n es">{project.problem.es}</span>
                  <span class="i18n en">{project.problem.en}</span>
                </dd>
              </div>
              <div>
                <dt>
                  <span class="i18n es">Mi rol</span>
                  <span class="i18n en">My role</span>
                </dt>
                <dd>
                  <span class="i18n es">{project.role.es}</span>
                  <span class="i18n en">{project.role.en}</span>
                </dd>
              </div>
              <div>
                <dt>
                  <span class="i18n es">Resultado</span>
                  <span class="i18n en">Outcome</span>
                </dt>
                <dd>
                  <span class="i18n es">{project.outcome.es}</span>
                  <span class="i18n en">{project.outcome.en}</span>
                </dd>
              </div>
            </dl>
          </div>
          <div class="case-media" data-carousel tabindex="0" aria-label={`Carousel for ${project.title.en}`}>
            <div class="case-carousel-frame" data-carousel-frame>
              {project.slides.map((slide, slideIndex) => (
                <img
                  src={slide.src}
                  alt={`${project.title.en} slide ${slide.index}`}
                  class:list={['case-slide', slideIndex === 0 && 'is-active']}
                  loading="lazy"
                  width="1080"
                  height="1080"
                  data-carousel-slide
                  aria-hidden={slideIndex === 0 ? 'false' : 'true'}
                />
              ))}
              <button type="button" class="canva-arrow case-arrow prev" data-carousel-prev aria-label={`Previous slide for ${project.title.en}`}>
                ‹
              </button>
              <button type="button" class="canva-arrow case-arrow next" data-carousel-next aria-label={`Next slide for ${project.title.en}`}>
